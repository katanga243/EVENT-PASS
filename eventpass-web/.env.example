# ── Database (Neon Postgres) ──────────────────────────────────
# Get this from https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@host/eventpass?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-32-random-bytes"

# ── JWT (for QR ticket tokens) ────────────────────────────────
JWT_SECRET="replace-me-with-another-secret"

# ── Stripe (TEST mode only) ───────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Resend (email) ────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="tickets@yourdomain.com"

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"